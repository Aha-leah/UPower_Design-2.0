{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD Input",
  "description": "产品需求文档（可执行版）的结构化 JSON 格式。替代 prd(input).md，减少格式 token 开销。",
  "type": "object",
  "required": ["project_name", "target_user", "mental_state", "emotion_goal", "metaphor", "omtm", "primary_terminal", "scope", "features"],
  "properties": {
    "project_name": {
      "type": "string",
      "description": "项目名称"
    },
    "target_user": {
      "type": "string",
      "description": "§1.2 目标用户：一句话，含身份+使用场景",
      "minLength": 10,
      "not_allowed": ["所有用户", "大众"]
    },
    "mental_state": {
      "type": "string",
      "description": "§1.2 用户心智：情绪词（焦虑/赶时间/探索/求稳/恐惧/期待/好奇/迷茫）",
      "enum_hint": ["焦虑", "赶时间", "探索", "求稳", "恐惧", "期待", "好奇", "迷茫"]
    },
    "emotion_goal": {
      "type": "string",
      "description": "§1.3 情绪目标：用户感受词",
      "not_allowed": ["提升体验", "好用", "简洁", "高效", "方便", "易用", "流畅", "优化"]
    },
    "metaphor": {
      "type": "string",
      "description": "§1.3 核心隐喻：现实世界物体",
      "not_allowed": ["平台", "系统", "工具", "产品", "应用"]
    },
    "aha_moment": {
      "type": "string",
      "description": "§1.3 成功瞬间：触发条件 + 用户感受"
    },
    "omtm": {
      "type": "object",
      "required": ["metric", "definition", "target"],
      "properties": {
        "metric": { "type": "string", "description": "核心指标名称" },
        "definition": { "type": "string", "description": "口径：如何计算" },
        "target": { "type": "string", "description": "目标值" }
      }
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "metric": { "type": "string" },
          "definition": { "type": "string" },
          "threshold": { "type": "string" }
        }
      }
    },
    "primary_terminal": {
      "type": "string",
      "enum": ["Web", "Mobile", "Landing", "Desktop"],
      "description": "§2.4 主终端（单选）"
    },
    "primary_action": {
      "type": "string",
      "description": "首要动作（CTA）"
    },
    "info_density": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "信息密度目标"
    },
    "scope": {
      "type": "object",
      "required": ["in", "out"],
      "properties": {
        "in": { "type": "array", "items": { "type": "string" }, "description": "本次必须做" },
        "out": { "type": "array", "items": { "type": "string" }, "description": "本次不做" }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "feature", "priority", "value", "acceptance"],
        "properties": {
          "module": { "type": "string" },
          "feature": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "value": { "type": "string" },
          "acceptance": { "type": "string" }
        }
      },
      "minItems": 1
    }
  }
}
